APP_ENV=production
APP_ACCESS_TOKEN=replace-with-a-long-random-access-code
DATABASE_URL=sqlite:///./storage/app.db
STORAGE_DIR=./storage
REDIS_URL=redis://redis:6379/0
WORKER_FALLBACK_TO_THREAD=false
WORKER_MODE=fork
MAX_PDF_SIZE_MB=200
MAX_PROCESS_PAGES=10
CORS_ORIGINS=http://localhost:8543
MAX_ACTIVE_TASKS=5
RUNNING_TASK_STALE_SECONDS=7200
SETTINGS_ENCRYPTION_KEY=

# Security & Session Settings (secure cookies should be true in production HTTPS setups)
COOKIE_SECURE=true

# Data Retention Policy (0 or empty means never delete automatically; set to positive integer for days)
AUDIO_RETENTION_DAYS=0

# Concurrency Controls (limiting total concurrent API/TTS worker calls)
MAX_CONCURRENT_AI_REQUESTS=3
MAX_CONCURRENT_TTS_REQUESTS=5

