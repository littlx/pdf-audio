APP_ENV=production
APP_ACCESS_TOKEN=replace-with-a-long-random-access-code
DATABASE_URL=sqlite:///./storage/app.db
STORAGE_DIR=./storage
REDIS_URL=redis://redis:6379/0
WORKER_FALLBACK_TO_THREAD=false
WORKER_MODE=fork
MAX_PDF_SIZE_MB=200
MAX_PROCESS_PAGES=10
CORS_ORIGINS=http://localhost:8543
MAX_ACTIVE_TASKS=5
RUNNING_TASK_STALE_SECONDS=7200
SETTINGS_ENCRYPTION_KEY=
COOKIE_SECURE=false
